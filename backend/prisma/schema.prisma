datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  password String
  name     String
  role     String  // e.g., "ADMIN", "DISPATCHER", "DRIVER"
  driver   Driver?
}

model Driver {
  id            Int       @id @default(autoincrement())
  name          String
  licenseNumber String    @unique
  status        String    @default("AVAILABLE") // AVAILABLE, ON_TRIP, INACTIVE
  userId        Int?      @unique
  user          User?     @relation(fields: [userId], references: [id])
  vehicle       Vehicle?
  trips         Trip[]
}

model Vehicle {
  id           Int           @id @default(autoincrement())
  plateNumber  String        @unique
  model        String
  status       String        @default("ACTIVE") // ACTIVE, MAINTENANCE, OUT_OF_SERVICE
  driverId     Int?          @unique
  driver       Driver?       @relation(fields: [driverId], references: [id])
  trips        Trip[]
  maintenances Maintenance[]
}

model Trip {
  id           Int       @id @default(autoincrement())
  vehicleId    Int
  vehicle      Vehicle   @relation(fields: [vehicleId], references: [id])
  driverId     Int
  driver       Driver    @relation(fields: [driverId], references: [id])
  routeDetails String
  status       String    @default("PLANNED") // PLANNED, IN_PROGRESS, COMPLETED, CANCELLED
  startTime    DateTime?
  endTime      DateTime?
}

model Maintenance {
  id          Int      @id @default(autoincrement())
  vehicleId   Int
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  description String
  cost        Float
  status      String   @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED
  date        DateTime @default(now())
}
