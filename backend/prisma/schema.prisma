datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RoleName {
  FleetManager
  Driver
  SafetyOfficer
  FinancialAnalyst
}

enum VehicleStatus {
  Available
  OnTrip
  InShop
  Retired
}

enum DriverStatus {
  Available
  OnTrip
  OffDuty
  Suspended
}

enum TripStatus {
  Draft
  Dispatched
  Completed
  Cancelled
}

enum MaintenanceStatus {
  Active
  Closed
}

enum ExpenseCategory {
  toll
  maintenance
  other
}

model Role {
  id    String   @id @default(uuid()) @db.Uuid
  name  RoleName
  users User[]
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @db.VarChar(100)
  email         String   @unique @db.VarChar(255)
  password_hash String
  role_id       String   @db.Uuid
  role          Role     @relation(fields: [role_id], references: [id])
  created_at    DateTime @default(now())
  trips         Trip[]
}

model Vehicle {
  id                  String           @id @default(uuid()) @db.Uuid
  registration_number String           @unique @db.VarChar(30)
  name_model          String           @db.VarChar(100)
  type                String           @db.VarChar(50)
  max_load_capacity   Decimal          @db.Decimal(10, 2)
  odometer            Decimal          @db.Decimal(12, 2)
  acquisition_cost    Decimal          @db.Decimal(12, 2)
  status              VehicleStatus
  region              String           @db.VarChar(100)
  created_at          DateTime         @default(now())
  updated_at          DateTime         @default(now()) @updatedAt
  trips               Trip[]
  maintenances        MaintenanceLog[]
  fuelLogs            FuelLog[]
  expenses            Expense[]

  @@index([status])
}

model Driver {
  id                  String       @id @default(uuid()) @db.Uuid
  name                String       @db.VarChar(100)
  license_number      String       @unique @db.VarChar(50)
  license_category    String       @db.VarChar(20)
  license_expiry_date DateTime     @db.Date
  contact_number      String       @db.VarChar(20)
  safety_score        Decimal      @db.Decimal(5, 2)
  status              DriverStatus
  created_at          DateTime     @default(now())
  updated_at          DateTime     @default(now()) @updatedAt
  trips               Trip[]

  @@index([status])
}

model Trip {
  id               String      @id @default(uuid()) @db.Uuid
  trip_number      String      @unique @db.VarChar(30)
  source           String      @db.VarChar(255)
  destination      String      @db.VarChar(255)
  vehicle_id       String      @db.Uuid
  vehicle          Vehicle     @relation(fields: [vehicle_id], references: [id])
  driver_id        String      @db.Uuid
  driver           Driver      @relation(fields: [driver_id], references: [id])
  created_by       String      @db.Uuid
  user             User        @relation(fields: [created_by], references: [id])
  cargo_weight     Decimal     @db.Decimal(10, 2)
  planned_distance Decimal     @db.Decimal(10, 2)
  start_odometer   Decimal?    @db.Decimal(12, 2)
  final_odometer   Decimal?    @db.Decimal(12, 2)
  fuel_consumed    Decimal?    @db.Decimal(10, 2)
  revenue          Decimal?    @db.Decimal(12, 2)
  status           TripStatus
  created_at       DateTime    @default(now())
  updated_at       DateTime    @default(now()) @updatedAt
  dispatched_at    DateTime?
  completed_at     DateTime?
  cancelled_at     DateTime?
  fuelLogs         FuelLog[]

  @@index([status])
  @@index([vehicle_id])
  @@index([driver_id])
}

model MaintenanceLog {
  id          String            @id @default(uuid()) @db.Uuid
  vehicle_id  String            @db.Uuid
  vehicle     Vehicle           @relation(fields: [vehicle_id], references: [id])
  description String
  cost        Decimal           @db.Decimal(12, 2)
  status      MaintenanceStatus
  opened_at   DateTime          @default(now())
  closed_at   DateTime?
  updated_at  DateTime          @default(now()) @updatedAt
}

model FuelLog {
  id         String   @id @default(uuid()) @db.Uuid
  vehicle_id String   @db.Uuid
  vehicle    Vehicle  @relation(fields: [vehicle_id], references: [id])
  trip_id    String?  @db.Uuid
  trip       Trip?    @relation(fields: [trip_id], references: [id])
  liters     Decimal  @db.Decimal(10, 2)
  cost       Decimal  @db.Decimal(12, 2)
  log_date   DateTime @db.Date
  updated_at DateTime @default(now()) @updatedAt
}

model Expense {
  id           String          @id @default(uuid()) @db.Uuid
  vehicle_id   String          @db.Uuid
  vehicle      Vehicle         @relation(fields: [vehicle_id], references: [id])
  category     ExpenseCategory
  amount       Decimal         @db.Decimal(12, 2)
  expense_date DateTime        @db.Date
  notes        String?
  updated_at   DateTime        @default(now()) @updatedAt
}
